---
// ChatBox — main interaction component
// Orchestrates the 4-step pipeline: translate → generate → validate → publish

export interface Props {
  supabaseUrl?: string;
  supabaseAnonKey?: string;
}

const { supabaseUrl, supabaseAnonKey } = Astro.props;
---

<div
  id="chat-root"
  class="flex flex-col h-screen bg-surface"
  data-supabase-url={supabaseUrl}
  data-supabase-anon-key={supabaseAnonKey}
>
  <!-- Header -->
  <header class="border-b border-border px-6 py-3 flex-shrink-0">
    <div class="max-w-5xl mx-auto flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center text-sm font-bold text-white">
          EB
        </div>
        <div>
          <h1 class="text-sm font-semibold text-white leading-tight">Extension Builder</h1>
          <p class="text-[11px] text-gray-500 leading-tight">MakeCode Arcade · AI Generator</p>
        </div>
      </div>

      <!-- Pipeline status (visible during execution) -->
      <div id="pipeline-steps" class="hidden items-center gap-1">
        <span class="pstep" data-step="translate">Traducir</span>
        <span class="text-gray-700 text-[10px] mx-0.5">→</span>
        <span class="pstep" data-step="generate">Generar</span>
        <span class="text-gray-700 text-[10px] mx-0.5">→</span>
        <span class="pstep" data-step="validate">Validar</span>
        <span class="text-gray-700 text-[10px] mx-0.5">→</span>
        <span class="pstep" data-step="publish">Publicar</span>
      </div>
    </div>
  </header>

  <!-- Messages area -->
  <div id="messages" class="flex-1 overflow-y-auto px-4 sm:px-6">
    <div class="max-w-3xl mx-auto py-6 space-y-4">
      <!-- Welcome message -->
      <div class="flex gap-3 items-start message-enter">
        <div class="w-7 h-7 rounded-lg bg-emerald-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5">
          EB
        </div>
        <div class="bg-surface-elevated border border-border rounded-2xl rounded-tl-sm px-4 py-3 max-w-[85%] sm:max-w-[75%]">
          <p class="text-sm text-gray-300 leading-relaxed">
            Decime qué extensión de <span class="text-emerald-400 font-medium">MakeCode Arcade</span> querés crear y la genero paso a paso.
          </p>
          <p class="text-xs text-gray-600 mt-2 leading-relaxed">
            Ej: <span class="text-gray-500 italic">"un shooter espacial con movimiento por flechas, disparo con A, enemigos que aparecen desde arriba cada 2 segundos, sistema de puntaje y timer de 60 segundos"</span>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Input area -->
  <div class="border-t border-border px-4 sm:px-6 py-4 flex-shrink-0">
    <div class="max-w-3xl mx-auto">
      <form id="chat-form" class="flex gap-3 items-end">
        <div class="flex-1 relative">
          <textarea
            id="prompt-input"
            rows="1"
            placeholder="Describí tu extensión..."
            class="w-full bg-surface-elevated border border-border hover:border-border-light focus:border-emerald-500/50 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 resize-none outline-none transition-colors"
          ></textarea>
        </div>
        <button
          type="submit"
          id="send-btn"
          disabled
          class="bg-emerald-600 hover:bg-emerald-500 disabled:bg-gray-800 disabled:text-gray-600 text-white rounded-xl px-5 py-3 text-sm font-medium transition-all disabled:cursor-not-allowed flex items-center gap-2 shrink-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          Generar
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const root = document.getElementById("chat-root")!;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const input = document.getElementById("prompt-input") as HTMLTextAreaElement;
  const sendBtn = document.getElementById("send-btn") as HTMLButtonElement;
  const messages = document.getElementById("messages")!;
  const pipelineSteps = document.getElementById("pipeline-steps")!;
  const msgContainer = messages.querySelector(".max-w-3xl")!;

  const supabaseUrl = root.dataset.supabaseUrl || "";
  const supabaseAnonKey = root.dataset.supabaseAnonKey || "";
  const functionsBase = import.meta.env.DEV
    ? "http://localhost:54321/functions/v1"
    : `${supabaseUrl}/functions/v1`;

  // Auto-resize textarea
  input.addEventListener("input", () => {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 120) + "px";
    sendBtn.disabled = !input.value.trim();
  });

  // ENTER to send (Shift+ENTER for newline)
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      form.dispatchEvent(new Event("submit"));
    }
  });

  // Pipeline step definitions
  const STEPS = [
    { id: "translate", label: "Traducir", desc: "Prompt → DSL" },
    { id: "generate", label: "Generar", desc: "DSL → Código" },
    { id: "validate", label: "Validar", desc: "Verificar código" },
    { id: "publish", label: "Publicar", desc: "GitHub repo" },
  ];

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const prompt = input.value.trim();
    if (!prompt) return;

    // Reset UI
    input.disabled = true;
    sendBtn.disabled = true;
    input.value = "";
    input.style.height = "auto";
    pipelineSteps.classList.remove("hidden");

    // Add user message
    addMessage("user", prompt);

    // Initialize pipeline steps
    const pipelineEl = document.createElement("div");
    pipelineEl.className = "flex gap-3 items-start message-enter";
    pipelineEl.innerHTML = `
      <div class="w-7 h-7 rounded-lg bg-emerald-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5">EB</div>
      <div class="flex-1 min-w-0">
        <div class="pipeline-progress space-y-1.5">
          ${STEPS.map((s, i) => `
            <div class="step-row flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-300" data-step="${s.id}">
              <div class="step-indicator w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium shrink-0 transition-all duration-300 border"></div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium step-label">${s.label}</div>
                <div class="text-[11px] text-gray-600 step-desc">${s.desc}</div>
              </div>
              <div class="step-status text-xs font-medium"></div>
            </div>
          `).join("")}
        </div>
        <div class="step-result mt-2"></div>
      </div>
    `;
    msgContainer.appendChild(pipelineEl);
    scrollToBottom();

    // Helper: update step state
    function setStepState(stepId: string, state: "idle" | "running" | "done" | "error", resultHtml?: string) {
      const row = pipelineEl.querySelector(`[data-step="${stepId}"]`) as HTMLElement;
      const indicator = row.querySelector(".step-indicator")!;
      const label = row.querySelector(".step-label")!;
      const status = row.querySelector(".step-status")!;
      const container = row;

      container.className = `step-row flex items-center gap-3 px-3 py-2 rounded-lg transition-all duration-300`;

      switch (state) {
        case "idle":
          indicator.className = "step-indicator w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium shrink-0 border border-gray-700 text-gray-600";
          indicator.textContent = "";
          label.className = "text-sm font-medium text-gray-600";
          status.textContent = "";
          container.classList.add("opacity-50");
          break;
        case "running":
          indicator.className = "step-indicator w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium shrink-0 border border-emerald-500/50 bg-emerald-500/10";
          indicator.innerHTML = '<div class="w-2 h-2 rounded-full bg-emerald-400 loading-dot"></div>';
          label.className = "text-sm font-medium text-emerald-400";
          status.textContent = "Procesando...";
          status.className = "step-status text-xs font-medium text-emerald-500";
          container.classList.add("bg-emerald-500/5", "border", "border-emerald-500/10");
          break;
        case "done":
          indicator.className = "step-indicator w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium shrink-0 bg-emerald-600 text-white";
          indicator.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
          label.className = "text-sm font-medium text-emerald-400";
          status.textContent = "✓ Listo";
          status.className = "step-status text-xs font-medium text-emerald-500";
          container.classList.add("opacity-80");
          break;
        case "error":
          indicator.className = "step-indicator w-6 h-6 rounded-full flex items-center justify-center text-xs font-medium shrink-0 bg-red-600 text-white";
          indicator.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>';
          label.className = "text-sm font-medium text-red-400";
          status.textContent = "Error";
          status.className = "step-status text-xs font-medium text-red-500";
          container.classList.add("bg-red-500/5", "border", "border-red-500/10");
          break;
      }

      // Set result content
      const resultDiv = pipelineEl.querySelector(".step-result")!;
      if (resultHtml) {
        resultDiv.innerHTML = resultHtml;
      }
    }

    // Init all steps as idle
    STEPS.forEach(s => setStepState(s.id, "idle"));

    try {
      // --- STEP 1: TRANSLATE ---
      setStepState("translate", "running");
      const translateRes = await fetch(`${functionsBase}/translate`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt }),
      });
      if (!translateRes.ok) {
        const err = await translateRes.json();
        throw new Error(err.error || "Error en traducción");
      }
      const { dsl, usage: translateUsage } = await translateRes.json();
      setStepState("translate", "done", `
        <details class="text-xs mt-1">
          <summary class="cursor-pointer text-gray-500 hover:text-gray-300 transition-colors select-none">
            <span class="text-emerald-500 font-medium">DSL YAML</span> — ${translateUsage?.total_tokens || "?"} tokens
          </summary>
          <div class="code-block mt-2">
            <pre><code class="language-yaml">${escapeHtml(dsl)}</code></pre>
          </div>
        </details>
      `);

      // --- STEP 2: GENERATE ---
      setStepState("generate", "running");
      const generateRes = await fetch(`${functionsBase}/generate`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ dsl }),
      });
      if (!generateRes.ok) {
        const err = await generateRes.json();
        throw new Error(err.error || "Error en generación");
      }
      const { files, usage: generateUsage } = await generateRes.json();
      setStepState("generate", "done", `
        <div class="text-xs mt-1 text-gray-500">
          <span class="text-emerald-500 font-medium">${files.length} archivos</span> — ${generateUsage?.total || "?"} tokens
          <div class="flex flex-wrap gap-1.5 mt-1.5">
            ${files.map((f: any) => `
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-surface-hover border border-border text-[11px] text-gray-400 font-mono">
                <svg class="w-3 h-3 ${f.name.endsWith(".ts") ? "text-blue-400" : f.name.endsWith(".json") ? "text-yellow-500" : "text-gray-500"}" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/>
                </svg>
                ${f.name}
              </span>
            `).join("")}
          </div>
        </div>
      `);

      // --- STEP 3: VALIDATE ---
      setStepState("validate", "running");
      const validateRes = await fetch(`${functionsBase}/validate`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ files }),
      });

      const validation = validateRes.ok ? await validateRes.json() : { valid: false, checks: [{ name: "error", passed: false, message: "Error de conexión" }] };

      const checksHtml = validation.checks?.map((c: any) => `
        <div class="flex items-center gap-2 py-1">
          <span class="${c.passed ? "text-emerald-500" : "text-red-500"} shrink-0">
            ${c.passed
              ? '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>'
              : '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>'}
          </span>
          <span class="text-[11px] text-gray-400 font-mono">${c.name}</span>
          ${c.message ? `<span class="text-[11px] ${c.passed ? "text-gray-600" : "text-red-400"}">${escapeHtml(c.message)}</span>` : ""}
        </div>
      `).join("") || "";

      if (validation.valid) {
        setStepState("validate", "done", `
          <div class="text-xs mt-1 text-gray-500">
            <span class="text-emerald-500 font-medium">✓ Validación exitosa</span> — ${validation.checks?.length || 0} checks
          </div>
        `);
      } else {
        setStepState("validate", "error", `
          <div class="text-xs mt-1.5 space-y-0.5 bg-red-500/5 border border-red-500/10 rounded-lg p-2.5">
            ${checksHtml}
            ${validation.fixed ? `<p class="text-[11px] text-amber-400 mt-1">⚠ Se intentó auto-corregir. Revisá los archivos.</p>` : ""}
          </div>
        `);
        throw new Error("La validación encontró errores");
      }

      // Step 3.5: Show file previews
      const filesHtml = files.map((f: any) => `
        <details class="text-xs">
          <summary class="cursor-pointer text-gray-500 hover:text-gray-300 transition-colors select-none py-1 flex items-center gap-2">
            <svg class="w-3.5 h-3.5 ${f.name.endsWith(".ts") ? "text-blue-400" : f.name.endsWith(".json") ? "text-yellow-500" : "text-gray-500"}" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/>
            </svg>
            <code class="text-gray-400">${f.name}</code>
            <span class="text-gray-700">(${(f.content.length / 1024).toFixed(1)} KB)</span>
          </summary>
          <div class="code-block mt-1.5">
            <pre><code>${escapeHtml(f.content)}</code></pre>
          </div>
        </details>
      `).join("");

      const resultContainer = pipelineEl.querySelector(".step-result")!;
      resultContainer.insertAdjacentHTML("beforeend", `
        <div class="mt-3 border-t border-border pt-3 space-y-1.5">
          <p class="text-xs text-gray-500 font-medium mb-2">Archivos generados</p>
          ${filesHtml}
        </div>
      `);

      // --- STEP 4: PUBLISH ---
      setStepState("publish", "running");
      const publishRes = await fetch(`${functionsBase}/publish`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ files }),
      });
      if (!publishRes.ok) {
        const err = await publishRes.json();
        throw new Error(err.error || "Error al publicar");
      }
      const { repoUrl } = await publishRes.json();
      setStepState("publish", "done", `
        <div class="mt-1.5">
          <a href="${repoUrl}" target="_blank"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600/10 border border-blue-500/20 hover:bg-blue-600/20 text-blue-400 rounded-lg text-xs font-medium transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Ver repositorio en GitHub
          </a>
        </div>
      `);

    } catch (err: any) {
      // Mark remaining steps as errored/idle
      const currentSteps = STEPS.map(s => s.id);
      let foundError = false;
      for (const step of currentSteps) {
        const row = pipelineEl.querySelector(`[data-step="${step}"]`);
        if (!row) continue;
        const status = row.querySelector(".step-status")?.textContent;
        if (status === "Procesando...") {
          if (!foundError) {
            setStepState(step, "error");
            const resultDiv = pipelineEl.querySelector(".step-result")!;
            resultDiv.insertAdjacentHTML("beforeend", `
              <div class="mt-2 text-xs bg-red-500/5 border border-red-500/10 rounded-lg p-2.5 text-red-400">
                <span class="font-medium">Error:</span> ${escapeHtml(err.message || "Error desconocido")}
              </div>
            `);
            foundError = true;
          }
        }
      }
    } finally {
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
      // Hide pipeline after a delay if done
      setTimeout(() => {
        const allDone = pipelineEl.querySelectorAll(".step-row .step-status");
        const allCompleted = Array.from(allDone).every(el => ["✓ Listo", "Error"].includes(el.textContent || ""));
        if (allCompleted) {
          // Keep visible, add subtle fade
        }
      }, 500);
    }
  });

  // --- Helper functions ---

  function addMessage(role: "user" | "system", text: string) {
    const div = document.createElement("div");
    div.className = "flex gap-3 items-start message-enter";
    const isUser = role === "user";
    div.innerHTML = `
      <div class="w-7 h-7 rounded-lg ${isUser ? "bg-blue-600" : "bg-gray-700"} flex items-center justify-center text-xs font-bold text-white flex-shrink-0 mt-0.5 order-${isUser ? "1" : "0"}">
        ${isUser ? "U" : "EB"}
      </div>
      <div class="${isUser ? "bg-blue-900/40 border-blue-800/50 ml-auto" : "bg-surface-elevated border-border"} border rounded-2xl ${isUser ? "rounded-tr-sm" : "rounded-tl-sm"} px-4 py-2.5 max-w-[85%] sm:max-w-[75%] ${isUser ? "" : ""}">
        <p class="text-sm text-gray-200 leading-relaxed whitespace-pre-wrap">${escapeHtml(text)}</p>
      </div>
    `;
    if (isUser) div.style.flexDirection = "row-reverse";
    msgContainer.appendChild(div);
    scrollToBottom();
  }

  function escapeHtml(text: string): string {
    return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  function scrollToBottom() {
    messages.scrollTop = messages.scrollHeight;
  }
</script>

<style>
  .message-enter {
    animation: messageSlideIn 0.3s ease-out;
  }
  @keyframes messageSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .code-block pre code {
    display: block;
    white-space: pre;
    overflow-x: auto;
  }
</style>
